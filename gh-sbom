#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"

usage() {
  cat <<'EOF'
gh-sbom: export and aggregate SBOMs from GitHub's dependency graph

Uses GitHub's native SBOM endpoint (GET /repos/{owner}/{repo}/dependency-graph/sbom),
so there is no cloning and no local scanning -- one REST call per repo.

USAGE
  gh sbom <org> [flags]           Fetch SBOMs for every repo in an org
  gh sbom <owner>/<repo> [flags]  Fetch the SBOM for a single repo

FLAGS
  -o, --output <dir>     Directory for raw SBOM JSON files (default: sboms)
  -t, --tsv <file>       Combined TSV output path (default: combined.tsv)
  -l, --limit <n>        Max repos to list from the org (default: 1000)
  -n, --top <n>          Rows in the "most common packages" rollup (default: 20)
      --include-archived Include archived repos (skipped by default)
      --skip-fetch       Re-aggregate existing JSON in the output dir; no API calls
  -v, --version          Print version
  -h, --help             Show this help

OUTPUT
  <output>/<repo>.json   Raw SPDX SBOM per repo
  <tsv>                  Columns: repo, ecosystem, package, version

EXAMPLES
  gh sbom my-org
  gh sbom cli/cli
  gh sbom my-org --top 50

  # unique packages across the whole org
  cut -f3 combined.tsv | tail -n +2 | sort -u

  # most common dependency org-wide
  cut -f3 combined.tsv | tail -n +2 | sort | uniq -c | sort -rn | head -30
EOF
}

err()  { printf '%s\n' "$*" >&2; }
die()  { err "error: $*"; exit 1; }

TARGET=""
OUT_DIR="sboms"
TSV_FILE="combined.tsv"
LIMIT=1000
TOP=20
INCLUDE_ARCHIVED=false
SKIP_FETCH=false

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -v|--version) echo "gh-sbom $VERSION"; exit 0 ;;
    -o|--output) OUT_DIR="${2:?--output requires a value}"; shift 2 ;;
    -t|--tsv) TSV_FILE="${2:?--tsv requires a value}"; shift 2 ;;
    -l|--limit) LIMIT="${2:?--limit requires a value}"; shift 2 ;;
    -n|--top) TOP="${2:?--top requires a value}"; shift 2 ;;
    --include-archived) INCLUDE_ARCHIVED=true; shift ;;
    --skip-fetch) SKIP_FETCH=true; shift ;;
    -*) die "unknown flag: $1 (see gh sbom --help)" ;;
    *)
      [ -n "$TARGET" ] && die "unexpected argument: $1"
      TARGET="$1"; shift ;;
  esac
done

command -v jq >/dev/null 2>&1 || die "jq is required (https://jqlang.org)"

if ! $SKIP_FETCH; then
  [ -n "$TARGET" ] || { usage >&2; exit 1; }
fi

# Extracts one TSV row per dependency. The repo's own root package (the one the
# SPDX document DESCRIBES) is excluded so rollups only count real dependencies.
JQ_EXTRACT='
  ((.sbom.relationships // []) | map(select(.relationshipType == "DESCRIBES") | .relatedSpdxElement)) as $roots
  | .sbom.packages[]?
  | select(.name != null)
  | .SPDXID as $id
  | select(($roots | index($id)) | not)
  | (first(.externalRefs[]? | select(.referenceType == "purl") | .referenceLocator) // "") as $purl
  | ($purl | if startswith("pkg:") then (split(":")[1] | split("/")[0]) else "unknown" end) as $eco
  | [$repo, $eco, .name, (.versionInfo // "unknown")]
  | @tsv
'

fetch_sboms() {
  local owner repos repo_count remaining i repo ok=0 failed=0 empty=0
  local failed_repos=()

  if [[ "$TARGET" == */* ]]; then
    owner="${TARGET%%/*}"
    repos="${TARGET#*/}"
  else
    owner="$TARGET"
    local list_filter='.[].name'
    $INCLUDE_ARCHIVED || list_filter='.[] | select(.isArchived | not) | .name'
    err "Listing repos for $owner..."
    repos=$(gh repo list "$owner" --limit "$LIMIT" --json name,isArchived --jq "$list_filter") \
      || die "could not list repos for '$owner'"
    [ -n "$repos" ] || die "no repos found for '$owner'"
  fi

  repo_count=$(printf '%s\n' "$repos" | wc -l | tr -d ' ')
  remaining=$(gh api rate_limit --jq '.resources.core.remaining' 2>/dev/null || true)
  if [[ "$remaining" =~ ^[0-9]+$ ]] && [ "$remaining" -lt "$repo_count" ]; then
    err "warning: only $remaining API requests remaining this hour for $repo_count repos"
  fi

  mkdir -p "$OUT_DIR"
  i=0
  while IFS= read -r repo; do
    i=$((i + 1))
    err "[$i/$repo_count] $owner/$repo"
    if gh api "repos/$owner/$repo/dependency-graph/sbom" > "$OUT_DIR/$repo.json" 2>/dev/null; then
      ok=$((ok + 1))
      if [ "$(jq '.sbom.packages | length' "$OUT_DIR/$repo.json")" -le 1 ]; then
        empty=$((empty + 1))
        err "  note: no dependencies detected (dependency graph disabled, or no supported manifests)"
      fi
    else
      failed=$((failed + 1))
      failed_repos+=("$repo")
      rm -f "$OUT_DIR/$repo.json"
      err "  failed (dependency graph disabled, or no access)"
    fi
    sleep 0.1  # be nice to rate limits on large orgs
  done <<< "$repos"

  err ""
  err "Fetched $ok/$repo_count SBOMs into $OUT_DIR/ ($empty with no dependencies)"
  if [ "$failed" -gt 0 ]; then
    err "Failed ($failed): ${failed_repos[*]}"
    err "For private repos, an admin may need to enable the dependency graph under"
    err "Settings -> Advanced Security -> Dependency graph."
  fi
}

aggregate() {
  local f repo files
  files=$(find "$OUT_DIR" -maxdepth 1 -name '*.json' 2>/dev/null | sort)
  [ -n "$files" ] || die "no SBOM JSON files in $OUT_DIR/"

  printf 'repo\tecosystem\tpackage\tversion\n' > "$TSV_FILE"
  while IFS= read -r f; do
    repo=$(basename "$f" .json)
    jq -r --arg repo "$repo" "$JQ_EXTRACT" "$f" >> "$TSV_FILE"
  done <<< "$files"
}

summarize() {
  local rows repos uniq_pkgs
  rows=$(($(wc -l < "$TSV_FILE") - 1))
  repos=$(tail -n +2 "$TSV_FILE" | cut -f1 | sort -u | wc -l | tr -d ' ')
  uniq_pkgs=$(tail -n +2 "$TSV_FILE" | cut -f3 | sort -u | wc -l | tr -d ' ')

  echo ""
  echo "Wrote $TSV_FILE: $rows dependency entries, $uniq_pkgs unique packages across $repos repos"
  if [ "$rows" -gt 0 ] && [ "$TOP" -gt 0 ]; then
    echo ""
    echo "Top $TOP packages by repo count:"
    tail -n +2 "$TSV_FILE" | cut -f1,3 | sort -u | cut -f2 \
      | sort | uniq -c | sort -rn | head -n "$TOP" \
      | awk '{ count=$1; $1=""; sub(/^ /,""); printf "  %4d  %s\n", count, $0 }'
  fi
}

$SKIP_FETCH || fetch_sboms
aggregate
summarize
